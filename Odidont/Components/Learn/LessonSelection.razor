<div class="accordion accordion-flush" id="accordion">
    @foreach (var lesson in Lessons)
    {
        <div class="accordion-item">
            <h1 class="accordion-header">
                <button class="accordion-button fs-1" style="font-weight: 600 !important;" type="button" data-bs-toggle="collapse" data-bs-target="#collapse@(lesson.Id)" aria-expanded="true" aria-controls="collapse@(lesson.Id)">
                    @(lesson.Title)
                </button>
            </h1>
            <div id="collapse@(lesson.Id)" class="accordion-collapse collapse m-3 p-3 bg-dark-subtle text-bg-dark-subtle" data-bs-parent="#accordion">
                @* @(lesson.Desc) *@
                <div class="row m-0">
                    @{
                        var desc = lesson.Description.Contains('\n') 
                            ? lesson.Description.Split('\n') 
                            : [lesson.Description];
                        for (var i = 0; i < desc.Length; i++)
                        {
                            @desc[i]
                            if (i < desc.Length - 1)
                            {
                                <br/>
                            }
                        }
                        @* foreach (var d in desc) *@
                        @* { *@
                        @*   @d *@
                        @*   <br/> *@
                        @* } *@
            
                    }
                </div>
                <div class="row m-0">
                    <button class="btn btn-primary mt-2 ms-auto ms-md-0 col-auto" 
                            type="button"
                            @onclick="async () => await ChangeLessonAsync(lesson)"
                            >
                        Go to lesson
                    </button>
                </div>
            </div>
        </div>
    }
</div>